# .env.production.example — copy to .env for production deployment
# NEVER commit a .env with real secrets to git

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password_here

# ── Application secrets ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_secret_key
REFRESH_SECRET_KEY=change_me_refresh_secret_key

# ── AI Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Integrations ─────────────────────────────────────────────────────────────
BREWERS_FRIEND_API_KEY=
ISPINDEL_WEBHOOK_SECRET=change_me_ispindel_secret
