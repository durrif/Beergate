# .env.example — Beergate v2
# Copy to .env and fill in values before running
#
# Generate SECRET_KEY and REFRESH_SECRET_KEY with:
#   openssl rand -hex 32

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development  # development | production

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://beergate:beergate@postgres:5432/beergate

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
REFRESH_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ─── CORS (comma-separated, NO wildcards in production) ───────────────────────
CORS_ORIGINS=https://www.beergate.es,http://localhost:5173

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── External APIs ────────────────────────────────────────────────────────────
BREWERS_FRIEND_API_KEY=
ISPINDEL_WEBHOOK_SECRET=

# ─── Email (invitation system) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@beergate.es
EMAILS_FROM_NAME=Beergate

# ─── Rate limiting ────────────────────────────────────────────────────────────
AI_RATE_LIMIT=20/minute
